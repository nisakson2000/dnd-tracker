{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "The Codex",
  "version": "0.7.1",
  "identifier": "com.codex.dndtracker",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": {
      "script": "npm run dev -- --host",
      "cwd": "../frontend"
    },
    "beforeBuildCommand": {
      "script": "npm run build",
      "cwd": "../frontend"
    }
  },
  "app": {
    "windows": [
      {
        "title": "The Codex — D&D Companion",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "dragDropEnabled": false
      }
    ],
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src 'self' codex:; style-src 'self' codex: 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' codex: https://fonts.gstatic.com; connect-src 'self' codex: ipc: http://ipc.localhost ws://localhost:* wss://localhost:* http://localhost:* https://localhost:* http://127.0.0.1:* ws://127.0.0.1:* ws://*:8787 wss://*:8787 https://gist.githubusercontent.com https://api.github.com https://raw.githubusercontent.com; img-src 'self' codex: data: blob:; object-src 'none'; script-src 'self' codex: 'unsafe-inline'"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/nisakson2000/dnd-tracker/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDUzQjJFNEU5NjdFOEM0MUUKUldRZXhPaG42ZVN5VStZSDdiT1BhUFZlLy9yZjU0SWQwam9kNG1GbjVJUnlrM255SkJrVHVJdWwK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ],
    "resources": [
      "resources/wiki.db",
      "resources/srd_monsters.json"
    ],
    "createUpdaterArtifacts": true
  }
}
